# Generated from deploy/.env.prod during deploy; do not edit deploy/.env.prod.pipecat-gateway directly.
# Pipecat gateway only receives OpenAI realtime, backend tool bridge auth, and gateway runtime settings.
LOG_LEVEL=INFO
MITR_BACKEND_BASE_URL=http://api:8080
MITR_BACKEND_INTERNAL_TOKEN=
MITR_GATEWAY_AUTH_MODE=
MITR_GATEWAY_PUBLIC_WS_URL=wss://api.example.com/ws
MITR_GATEWAY_CORS_ORIGINS=https://app.example.com
MITR_GATEWAY_WAKE_MODE=pipecat_phrase
MITR_GATEWAY_WAKE_PHRASES=hi mitr,hey mitr,hi mitra,hey mitra,hi reca,hey reca,hi rekha,hey rekha,hi r e k a,hey r e k a,hi reka,hey reka,hi esp,hey esp,hi e s p,हाय मित्र,हे मित्र,हाय रेका,हाय रेखा
MITR_GATEWAY_WAKE_IDLE_TIMEOUT_SEC=45
MITR_GATEWAY_LOG_TRANSCRIPTS=false
MITR_GATEWAY_BACKEND_TOOL_TIMEOUT_SEC=55
MITR_GATEWAY_TOOL_TIMEOUT_SEC=65
MITR_GATEWAY_ACK_SLOW_TOOLS=true
MITR_GATEWAY_SESSION_TIMEOUT_SEC=
MITR_GATEWAY_ECHO_SUPPRESSION=true
MITR_GATEWAY_INJECT_BOOT_CONTEXT=false
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_STT_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_STT_LANGUAGE=en
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_MAX_OUTPUT_TOKENS=1024
OPENAI_REALTIME_TURN_DETECTION=manual
OPENAI_REALTIME_INTERRUPT_RESPONSE=false
ESP32_AUDIO_IN_SAMPLE_RATE=16000
ESP32_AUDIO_OUT_SAMPLE_RATE=16000
