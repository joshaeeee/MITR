# -----------------------------------------------------------------------------
# Image references (set by CI or manually)
# -----------------------------------------------------------------------------
API_IMAGE=ghcr.io/OWNER/MITR-api:prod-latest
PIPECAT_GATEWAY_IMAGE=ghcr.io/OWNER/MITR-pipecat-gateway:prod-latest
REMINDER_IMAGE=ghcr.io/OWNER/MITR-api:prod-latest
WAKEWORD_WORKER_IMAGE=ghcr.io/OWNER/MITR-wakeword-worker:prod-latest
WAKEWORD_MODEL_MANIFEST_PATH=/app/models/hey_esp.meta.json

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=8080
TRUST_PROXY=true
LOG_LEVEL=info
CORS_ORIGINS=https://app.example.com
CORS_ALLOW_MISSING_ORIGIN=false
API_PUBLIC_BASE_URL=https://api.example.com
INTERNAL_API_BASE_URL=http://api:8080
RUN_DB_MIGRATIONS=true
VOICE_NOTES_STORAGE_DIR=var/voice-notes
VOICE_NOTES_ENCRYPTION_KEY_B64=
# Set true only after VOICE_NOTES_STORAGE_DIR is backed by encrypted storage and backup policy.
VOICE_NOTES_LOCAL_STORAGE_ACK_RISK=false
# Set true only after all previously exposed dev/pilot keys have been rotated.
SECURITY_KEYS_ROTATED_ACK=false
# Set true only after production secrets live outside the repo/workspace and are chmod 600 or secret-manager backed.
PROD_SECRETS_OUT_OF_REPO_ACK=false
# Set true only after the production Postgres volume/RDS instance has encryption at rest enabled.
POSTGRES_STORAGE_ENCRYPTION_ACK=false
# Set true only after automated Postgres backups/snapshots are encrypted and retention is configured.
POSTGRES_BACKUPS_ENCRYPTION_ACK=false
PIPECAT_GATEWAY_PUBLIC_WS_URL=wss://api.example.com/ws
PIPECAT_GATEWAY_PUBLIC_HTTP_URL=https://api.example.com
AWS_REGION=eu-north-1
CLOUDWATCH_LOG_GROUP=/mitr/prod
ENABLE_HTTPS=true
PUBLIC_HOSTNAME=api.example.com
ROOT_HOSTNAME=
WEB_HOSTNAME=
TLS_ADDITIONAL_HOSTNAMES=
TLS_CERT_NAME=
TLS_EMAIL=

# -----------------------------------------------------------------------------
# Pipecat gateway voice
# -----------------------------------------------------------------------------
MITR_GATEWAY_WAKE_MODE=pipecat_phrase
MITR_GATEWAY_WAKE_PHRASES=hi mitr,hey mitr,hi mitra,hey mitra,hi reca,hey reca,hi rekha,hey rekha,hi r e k a,hey r e k a,hi reka,hey reka,hi esp,hey esp,hi e s p,हाय मित्र,हे मित्र,हाय रेका,हाय रेखा
MITR_GATEWAY_WAKE_IDLE_TIMEOUT_SEC=45
MITR_GATEWAY_CORS_ORIGINS=https://app.example.com
MITR_GATEWAY_LOG_TRANSCRIPTS=false
OPENAI_REALTIME_STT_LANGUAGE=en
ESP32_AUDIO_OUTPUT_GAIN=0.85

# -----------------------------------------------------------------------------
# OpenAI Realtime
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/auto
AGENT_VOICE_PIPELINE=openai_realtime
GOOGLE_API_KEY=
INFERENCE_LLM_MODEL=moonshotai/kimi-k2-instruct
INFERENCE_STT_MODEL=cartesia/ink-whisper
INFERENCE_TTS_MODEL=cartesia/sonic-3
GOOGLE_REALTIME_MODEL=gemini-2.0-flash-exp
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-2
CARTESIA_VOICE_ID=794f9389-aac1-45b6-b726-9d9369183238
CARTESIA_LANGUAGE=hi
CARTESIA_BASE_URL=https://api.cartesia.ai
CARTESIA_CHUNK_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Sarvam STT + TTS
# -----------------------------------------------------------------------------
SARVAM_API_KEY=
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_STT_STREAMING=true
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_STREAMING=true
SATSANG_AMBIENCE_ENABLED=false

# -----------------------------------------------------------------------------
# Session and auth
# -----------------------------------------------------------------------------
AUTH_SESSION_TTL_SEC=3600
AUTH_REFRESH_TTL_SEC=2592000
AUTH_OTP_TTL_SEC=300
AUTH_REVOKED_SESSION_RETENTION_SEC=604800
AUTH_OTP_CONSUMED_RETENTION_SEC=86400
AUTH_OTP_DELIVERY_MODE=disabled
AUTH_DEV_OTP_BYPASS=false
AUTH_DEV_OTP_CODE=123456
AUTH_LOCKOUT_MAX_FAILURES=5
AUTH_LOCKOUT_WINDOW_SEC=900
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
GOOGLE_OAUTH_CLIENT_IDS=
APPLE_OAUTH_CLIENT_IDS=
DEVICE_TOKEN_TTL_SEC=86400
SESSION_IDLE_TIMEOUT_SEC=1800
DEVICE_CONVERSATION_IDLE_TIMEOUT_MS=20000
INTERNAL_SERVICE_TOKEN=
SHORT_CODE_PEPPER=

# -----------------------------------------------------------------------------
# External data stores (required)
# -----------------------------------------------------------------------------
# Use sslmode=verify-full for remote Postgres. Example:
# postgresql://USER:PASSWORD@HOST:5432/mitr?sslmode=verify-full
POSTGRES_URL=
REDIS_URL=redis://redis:6379
MEM0_API_KEY=
MEM0_BASE_URL=https://api.mem0.ai
MEM0_ORG_ID=
MEM0_PROJECT_ID=
MEM0_APP_ID=mitr-reca
MEM0_AGENT_ID=reca
MEM0_ADD_TIMEOUT_MS=5000
MEM0_SEARCH_TIMEOUT_MS=3500
MEM0_CONTEXT_SEARCH_TIMEOUT_MS=650
MEM0_SEARCH_THRESHOLD=0.1
MEM0_SEARCH_RERANK=false
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_CHECK_COMPATIBILITY=false
QDRANT_COLLECTION=religious_texts

# -----------------------------------------------------------------------------
# Embeddings / retrieval
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_PROVIDER_URL=https://openrouter.ai/api/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MAX_BATCH_SIZE=64
EMBEDDING_AUTH_TYPE=bearer
STORY_RETRIEVE_TIMEOUT_MS=7000

# -----------------------------------------------------------------------------
# News
# -----------------------------------------------------------------------------
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
EXA_DEFAULT_REGION=IN
EXA_DEFAULT_NUM_RESULTS=6
EXA_DEFAULT_RECENCY_DAYS=3
EXA_NEWS_SEARCH_TYPE=auto
EXA_NEWS_TEXT_MAX_CHARS=2600
EXA_NEWS_HIGHLIGHT_SENTENCES=3
EXA_NEWS_HIGHLIGHTS_PER_URL=3
EXA_NEWS_SUMMARY_STYLE=detailed

# -----------------------------------------------------------------------------
# Geocoding / Panchang / Gita
# -----------------------------------------------------------------------------
GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com/v1
GEOCODING_TIMEOUT_MS=3000
GEOCODING_DEFAULT_COUNTRY=IN
PROKERALA_CLIENT_ID=
PROKERALA_CLIENT_SECRET=
PROKERALA_BASE_URL=https://api.prokerala.com/v2
PROKERALA_TOKEN_URL=https://api.prokerala.com/token
PROKERALA_TIMEOUT_MS=7000
BHAGAVAD_GITA_PROVIDER=vedicscriptures
BHAGAVAD_GITA_API_BASE_URL=https://vedicscriptures.github.io
BHAGAVAD_GITA_API_KEY=
BHAGAVAD_GITA_TIMEOUT_MS=3500

# -----------------------------------------------------------------------------
# Media resolver
# -----------------------------------------------------------------------------
YTDLP_PATH=yt-dlp
YTDLP_TIMEOUT_MS=20000
YTDLP_SEARCH_TIMEOUT_MS=7000
YTDLP_STREAM_TIMEOUT_MS=8000
YOUTUBE_MEDIA_TIMEOUT_MS=12000

# -----------------------------------------------------------------------------
# Long-session recovery
# -----------------------------------------------------------------------------
LONG_SESSION_STALE_MS=45000
INSIGHTS_REALTIME_POLL_SEC=60
DIGEST_JOB_CRON_UTC=* * * * *
DIGEST_DEFAULT_HOUR=20
DIGEST_DEFAULT_MINUTE=30
EXPO_ACCESS_TOKEN=
MAINTENANCE_CLEANUP_INTERVAL_SEC=900
USER_EVENT_STREAM_RETENTION_SEC=1209600
