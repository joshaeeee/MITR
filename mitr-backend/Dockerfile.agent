FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/* \
  && pip install --no-cache-dir uv

WORKDIR /app

COPY pipecat-gateway/pyproject.toml pipecat-gateway/uv.lock ./
RUN uv sync --frozen

COPY pipecat-gateway/ ./

EXPOSE 7860
CMD ["uv", "run", "python", "-m", "mitr_pipecat_gateway.server"]
