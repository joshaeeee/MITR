{
  "name": "mitr-voice-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lightweight multi-provider voice gateway for Mitr ESP32 (no Pipecat). WebSocket PCM16 in/out; ElevenLabs/Sarvam STT+TTS, Claude LLM.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "serve": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "bench": "tsx bench/run-bench.ts",
    "bench:make-audio": "tsx bench/make-audio.ts"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "sarvamai": "^1.1.7",
    "dotenv": "^16.4.7",
    "ws": "^8.19.0",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.8",
    "@types/ws": "^8.5.13",
    "typescript": "^5.8.2"
  }
}
