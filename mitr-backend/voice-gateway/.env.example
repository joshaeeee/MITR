# ---- voice-gateway (.env) ----
# Copy to .env and fill in. Reuses the same var names as the Pipecat gateway where
# possible, so you can share the prod env. NEVER commit real keys (repo is public).

# ---- server ----
# 7861 by default so it runs alongside the Pipecat gateway (7860) for A/B benchmarks.
# Loopback by default. Set 0.0.0.0 ONLY behind a reverse proxy (nginx) in prod —
# local auth mode with no pinned device id refuses to boot on a non-loopback host.
MITR_GATEWAY_HOST=127.0.0.1
MITR_GATEWAY_PORT=7861
MITR_GATEWAY_PUBLIC_WS_URL=ws://localhost:7861/ws
LOG_LEVEL=info

# ---- auth ----
# "local" trusts the deviceId (dev/benchmark only). "backend" verifies via the API.
MITR_GATEWAY_AUTH_MODE=local
MITR_GATEWAY_LOCAL_DEVICE_ID=
MITR_BACKEND_BASE_URL=
MITR_BACKEND_INTERNAL_TOKEN=

# ---- providers (ElevenLabs cascade is the default first stack) ----
MITR_GATEWAY_STT_PROVIDER=elevenlabs
MITR_GATEWAY_TTS_PROVIDER=elevenlabs
MITR_GATEWAY_LLM_PROVIDER=claude

# ---- audio wire format (ESP32 contract) ----
ESP32_AUDIO_IN_SAMPLE_RATE=16000
ESP32_AUDIO_OUT_SAMPLE_RATE=16000
ESP32_AUDIO_PACKET_MS=20
ESP32_AUDIO_OUTPUT_GAIN=1.0

# ---- ElevenLabs ----
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_STT_MODEL=scribe_v2_realtime
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_AUTO_MODE=true
# ELEVENLABS_STT_LANGUAGE=    # blank = auto-detect
# ELEVENLABS_TTS_LANGUAGE=

# ---- Claude ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=512
CLAUDE_TEMPERATURE=0.7

# ---- wake phrase (server-side; device streams continuously) ----
# Defaults to the same phrase set as the Pipecat gateway if unset.
# MITR_GATEWAY_WAKE_PHRASES=hi mitr,hey mitr,...
MITR_GATEWAY_WAKE_IDLE_TIMEOUT_SEC=45
MITR_GATEWAY_WAKE_PHRASE_PREROLL_SEC=4

# ---- VAD endpointer (firmware never signals end-of-turn) ----
MITR_GATEWAY_VAD_START_RMS=700
MITR_GATEWAY_VAD_STOP_RMS=450
MITR_GATEWAY_VAD_SILENCE_MS=700

# ---- echo suppression (half-duplex; device has no AEC) ----
MITR_GATEWAY_ECHO_SUPPRESSION=true
MITR_GATEWAY_ECHO_SUPPRESSION_TAIL_MS=2500

# ---- tools ----
# Tools call the backend; disable for a self-contained latency benchmark.
MITR_GATEWAY_TOOLS_ENABLED=true

# ---- benchmark ----
# MITR_GATEWAY_LATENCY_JSONL=./bench/results/turns.jsonl
